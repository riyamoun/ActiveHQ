# Application
APP_NAME=ActiveHQ
DEBUG=true
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/activehq
DB_ECHO=false

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS_STR=http://localhost:3000,http://localhost:5173

# Optional one-time setup key for /setup-database endpoint
# Keep empty to disable endpoint
SETUP_DATABASE_KEY=

# Monitoring
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Lead webhook / CRM endpoint (optional)
LEAD_WEBHOOK_URL=
