# Copy to: frontend/android/keystore.properties
# DO NOT COMMIT the real file or the .jks keystore — both are in .gitignore.
#
# Generate a keystore once (then back up the .jks file securely):
#   keytool -genkey -v -keystore activehq-upload.jks -alias activehq -keyalg RSA -keysize 2048 -validity 10000
#
# Place the .jks next to this file. Then fill in:

storeFile=activehq-upload.jks
storePassword=CHANGE_ME
keyAlias=activehq
keyPassword=CHANGE_ME
