# API URL (required for production; leave empty for local dev — Vite proxy uses /api)
# Vercel production: set in Project → Settings → Environment Variables
VITE_API_URL=https://activehq-api.onrender.com

# Public site URL (e.g. https://active-hq.vercel.app) for canonical links / SEO
VITE_APP_URL=

# Frontend monitoring (optional)
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
