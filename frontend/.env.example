# API URL (required for production, leave empty for local development)
# For Vercel: Set this to your Render backend URL (without trailing slash)
# Example: https://activehq-backend.onrender.com
VITE_API_URL=

# Public site URL used for canonical links and SEO
VITE_APP_URL=

# Frontend monitoring (optional)
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
