# Application
APP_NAME=ActiveHQ
DEBUG=true
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/activehq
DB_ECHO=false

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS_STR=http://localhost:3000,http://localhost:5173

# Optional one-time setup key for /setup-database endpoint
# Keep empty to disable endpoint
SETUP_DATABASE_KEY=

# Monitoring
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Lead webhook / CRM endpoint (optional)
LEAD_WEBHOOK_URL=

# WhatsApp: Interakt (India). API Key: https://app.interakt.ai/settings/developer-setting
INTERAKT_API_KEY=
INTERAKT_COUNTRY_CODE=+91
# Template code names from Interakt (templates list → template/codename/view)
INTERAKT_TEMPLATE_RENEWAL=
INTERAKT_TEMPLATE_PAYMENT_DUE=

# SMS fallback: Twilio (optional). Sender: 9958040484
MESSAGING_PHONE_NUMBER=9958040484
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=

# Cron: secret for GET /api/v1/automation/run-cron (Render Cron / scheduler)
CRON_SECRET=
