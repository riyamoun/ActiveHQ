<?xml version="1.0" encoding="utf-8"?>
<!--
  Disable auto-backup of any app data (we never want auth tokens or cached API
  responses ending up in Google's cloud backup). Required for Play Store
  Data Safety form: "We don't allow cloud backup of user data".
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
