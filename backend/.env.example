# Application
APP_NAME=ActiveHQ
DEBUG=true
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/activehq
DB_ECHO=false

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated list of allowed origins; match Vite dev port in frontend/vite.config.ts)
CORS_ORIGINS_STR=http://localhost:3002,http://localhost:5173

# Optional one-time setup key for /setup-database endpoint
# Keep empty to disable endpoint
SETUP_DATABASE_KEY=

# Monitoring
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Lead webhook / CRM endpoint (optional)
LEAD_WEBHOOK_URL=

# Picky Assist — WhatsApp + SMS (Push API)
# Get API token from Picky Assist → your project → API.
# Channel IDs: Settings → Channels (WhatsApp Cloud API is often 101; SMS automation is often 3).
PICKYASSIST_API_TOKEN=
PICKYASSIST_PUSH_URL=https://app.pickyassist.com/api/v2/push
PICKYASSIST_APPLICATION_WHATSAPP=
PICKYASSIST_APPLICATION_SMS=3

# Display / contact number shown in docs (not used for API auth)
MESSAGING_PHONE_NUMBER=9958040484

# Cron: secret for GET /api/v1/automation/run-cron (Render Cron / scheduler)
CRON_SECRET=

# Email (optional): set SMTP_FROM to your professional address e.g. info@activehq.fit
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
